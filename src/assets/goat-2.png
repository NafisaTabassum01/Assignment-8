<script>
  (function () {
    const modal = document.getElementById('ioConverterModal');
    const openBtn = document.getElementById('ioConverterToggle');
    const closeBtn = document.getElementById('ioConverterClose');
    const tabs = document.querySelectorAll('.io-tab');
    const panels = document.querySelectorAll('.io-tab-panel');

    const mmValue = document.getElementById('mmValue');
    const mmCombined = document.getElementById('mmCombined');

    const inchValue = document.getElementById('inchValue');
    const inchToMm = document.getElementById('inchToMm');

    const feetValue = document.getElementById('feetValue');
    const feetInchValue = document.getElementById('feetInchValue');
    const ftFeetInline = document.getElementById('ftFeetInline');
    const ftInchesInline = document.getElementById('ftInchesInline');
    const ftToMm = document.getElementById('ftToMm');

    function openModal() {
      modal.classList.add('active');
      modal.setAttribute('aria-hidden', 'false');
    }

    function closeModal() {
      modal.classList.remove('active');
      modal.setAttribute('aria-hidden', 'true');
    }

    openBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeModal();
    });

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        const selected = tab.getAttribute('data-tab');

        tabs.forEach(function (t) {
          t.classList.remove('active');
        });

        panels.forEach(function (p) {
          p.classList.remove('active');
        });

        tab.classList.add('active');
        document.getElementById('panel-' + selected).classList.add('active');
      });
    });

    function updateMmToFtIn() {
      const mm = parseFloat(mmValue.value);

      if (isNaN(mm) || mm < 0) {
        mmCombined.textContent = '0 ft 0.00 in';
        return;
      }

      const totalInches = mm / 25.4;
      const feet = Math.floor(totalInches / 12);
      const inches = totalInches - (feet * 12);

      mmCombined.textContent = feet + ' ft ' + inches.toFixed(2) + ' in';
    }

    function updateInToMm() {
      const inches = parseFloat(inchValue.value);

      if (isNaN(inches) || inches < 0) {
        inchToMm.textContent = '0 mm';
        return;
      }

      const mm = inches * 25.4;
      inchToMm.textContent = mm.toFixed(2) + ' mm';
    }

    function updateFtToMm() {
      const feet = parseFloat(feetValue.value);
      const inches = parseFloat(feetInchValue.value);

      const safeFeet = isNaN(feet) || feet < 0 ? 0 : feet;
      const safeInches = isNaN(inches) || inches < 0 ? 0 : inches;

      const totalInches = (safeFeet * 12) + safeInches;
      const mm = totalInches * 25.4;

      ftFeetInline.textContent = safeFeet;
      ftInchesInline.textContent = safeInches % 1 === 0 ? safeInches.toFixed(0) : safeInches.toFixed(2);
      ftToMm.textContent = mm.toFixed(2) + ' mm';
    }

    mmValue.addEventListener('input', updateMmToFtIn);
    inchValue.addEventListener('input', updateInToMm);
    feetValue.addEventListener('input', updateFtToMm);
    feetInchValue.addEventListener('input', updateFtToMm);
    updateMmToFtIn();
    updateInToMm();
    updateFtToMm();
  })();
</script>




</section>
