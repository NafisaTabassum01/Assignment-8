<script>
  (function() {
    class TimeAnnouncementBarak3btqstxuznmu2urzaigenblock0c5028bcjbrgw extends HTMLElement {
      constructor() {
        super();
        this.timezone = this.dataset.timezone || 'UTC';
        this.messages = [];
        this.currentMessageIndex = -1;
      }

      connectedCallback() {
        this.collectMessages();
        this.updateDisplay();
        this.startTimer();
      }

      disconnectedCallback() {
        if (this.timer) {
          clearInterval(this.timer);
        }
      }

      collectMessages() {
        const messageElements = this.querySelectorAll('.ai-time-announcement-bar__message-ak3btqstxuznmu2urzaigenblock0c5028bcjbrgw');
        messageElements.forEach((element) => {
          const startTime = element.dataset.startTime;
          const endTime = element.dataset.endTime;
          const daysString = element.dataset.days;
          const days = daysString ? daysString.split(',').filter(d => d).map(d => parseInt(d)) : [];

          this.messages.push({
            element: element,
            startTime: startTime,
            endTime: endTime,
            days: days
          });
        });
      }

      getCurrentTime() {
        const now = new Date();
        const options = { timeZone: this.timezone };
        const formatter = new Intl.DateTimeFormat('en-US', {
          ...options,
          hour: '2-digit',
          minute: '2-digit',
          hour12: false
        });
        const timeString = formatter.format(now);
        const dayFormatter = new Intl.DateTimeFormat('en-US', {
          ...options,
          weekday: 'short'
        });
        const dayString = dayFormatter.format(now);
        const dayMap = { 'Sun': 0, 'Mon': 1, 'Tue': 2, 'Wed': 3, 'Thu': 4, 'Fri': 5, 'Sat': 6 };
        const currentDay = dayMap[dayString];

        return { time: timeString, day: currentDay };
      }

      isTimeInRange(currentTime, startTime, endTime) {
        if (!startTime || !endTime) {
          return true;
        }

        const current = currentTime.split(':').map(n => parseInt(n));
        const start = startTime.split(':').map(n => parseInt(n));
        const end = endTime.split(':').map(n => parseInt(n));

        const currentMinutes = current[0] * 60 + current[1];
        const startMinutes = start[0] * 60 + start[1];
        const endMinutes = end[0] * 60 + end[1];

        if (endMinutes < startMinutes) {
          return currentMinutes >= startMinutes || currentMinutes <= endMinutes;
        } else {
          return currentMinutes >= startMinutes && currentMinutes <= endMinutes;
        }
      }

      updateDisplay() {
        const { time, day } = this.getCurrentTime();
        let foundMessage = false;

        this.messages.forEach((message, index) => {
          const isDayMatch = message.days.length === 0 || message.days.includes(day);
          const isTimeMatch = this.isTimeInRange(time, message.startTime, message.endTime);

          if (isDayMatch && isTimeMatch && !foundMessage) {
            message.element.classList.add('active');
            foundMessage = true;
            this.currentMessageIndex = index;
          } else {
            message.element.classList.remove('active');
          }
        });

        if (!foundMessage && this.currentMessageIndex !== -1) {
          this.currentMessageIndex = -1;
        }
      }

      startTimer() {
        this.timer = setInterval(() => {
          this.updateDisplay();
        }, 60000);
      }
    }

    customElements.define('time-announcement-bar-ak3btqstxuznmu2urzaigenblock0c5028bcjbrgw', TimeAnnouncementBarak3btqstxuznmu2urzaigenblock0c5028bcjbrgw);
  })();
</script>



