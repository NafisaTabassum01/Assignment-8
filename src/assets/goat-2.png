","submenu_type":"mega","submenu_mega_position":"fullwidth","title":"DIY \u0026 Industrial","submenu_mega_width":"1300","el_class":"indoors-menu"},"menus":[{"id":"tmenu-menu-542194","setting":{"item_layout":"html","title":"Menu item","item_display":true,"column_width":"4","custom_html":"\u003ca href=\"https:\/\/www.indooroutdoors.co.uk\/collections\/nukeson-tool-wall-panels\" title=\"Nukeson Tool Wall\"\u003e\n  \u003cdiv class=\"nav-banner nav-banner--nukeson\"\u003e\n    \u003cimg class=\"nav-banner__logo\" alt=\"Nukeson Tool Wall Panels\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1357\/3819\/files\/Nukeson_Tool_Wall.png\"\u003e\n  \u003c\/div\u003e\n\u003c\/a\u003e\n\n\u003cstyle\u003e\n\/* 1) Base banner box (reuse this for all) *\/\n.nav-banner {\n  width: 100%;\n  height: 220px;                 \/* fixed box height *\/\n  margin: 20px 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background-size: cover;\n  background-position: center;\n  position: relative;\n  overflow: hidden;\n}\n\n\/* Optional dark overlay so logos pop (tweak opacity) *\/\n.nav-banner::before {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  background: rgba(0,0,0,0.25);\n  pointer-events: none;\n}\n\n\/* 2) Logo rules (handles different logo sizes) *\/\n.nav-banner__logo {\n  position: relative;            \/* sits above overlay *\/\n  z-index: 1;\n  max-width: min(320px, 80%);    \/* never larger than 320px, but scales down on mobile *\/\n  max-height: 70%;               \/* stops tall logos taking over *\/\n  width: auto;\n  height: auto;\n  display: block;\n  transition: transform 0.25s ease;\n  will-change: transform;\n}\n\n\/* 3) One shared pulse animation *\/\n@keyframes navPulse {\n  0%   { transform: scale(1); }\n  50%  { transform: scale(1.08); }\n  100% { transform: scale(1); }\n}\n\n\/* Pulse on hover (box hover, not img hover) *\/\n.nav-banner:hover .nav-banner__logo {\n  animation: navPulse 0.8s ease-in-out infinite;\n}\n\n\/* 4) Nukeson specific background (only this line changes per banner) *\/\n.nav-banner--nukeson {\n  background-image: url('https:\/\/cdn.shopify.com\/s\/files\/1\/1357\/3819\/files\/NukesonToolWallSmall3.jpg?v=1772124368');\n}\n\n\/* Mobile spacing (optional) *\/\n@media (max-width: 767px) {\n  .nav-banner {\n    margin-top: 0;\n    height: 190px;               \/* slightly shorter on mobile *\/\n  }\n}\n\u003c\/style\u003e"},"menus":[]},{"id":"tmenu-menu-950125","setting":{"item_layout":"html","title":"Copy of Menu item","item_display":true,"column_width":"4","custom_html":" \u003ca href=\"https:\/\/www.indooroutdoors.co.uk\/collections\/blue-roll-holders\" title=\"MegaMaxx Blue Roll Holders\"\u003e\n  \u003cdiv class=\"nav-banner nav-banner--megamaxx-brh\"\u003e\n    \u003cimg class=\"nav-banner__logo\"\n         alt=\"MegaMaxx Blue Roll Holder Logo\"\n         src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1357\/3819\/files\/MegaMaxxBlueRollHolderLogo.png?v=1772124542\"\u003e\n  \u003c\/div\u003e\n\u003c\/a\u003e\n\n\u003cstyle\u003e\n\n\/* Base reusable banner box *\/\n.nav-banner {\n  width: 100%;\n  height: 220px;\n  margin: 20px 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background-size: cover;\n  background-position: center;\n  position: relative;\n  overflow: hidden;\n}\n\n\/* Optional overlay for contrast *\/\n.nav-banner::before {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  background: rgba(0,0,0,0.25);\n  pointer-events: none;\n}\n\n\/* Reusable logo rules *\/\n.nav-banner__logo {\n  position: relative;\n  z-index: 1;\n  max-width: min(360px, 85%);\n  max-height: 70%;\n  width: auto;\n  height: auto;\n  display: block;\n  transition: transform 0.25s ease;\n  will-change: transform;\n}\n\n\/* Shared pulse animation (define once globally ideally) *\/\n@keyframes navPulse {\n  0%   { transform: scale(1); }\n  50%  { transform: scale(1.08); }\n  100% { transform: scale(1); }\n}\n\n\/* Hover trigger *\/\n.nav-banner:hover .nav-banner__logo {\n  animation: navPulse 0.8s ease-in-out infinite;\n}\n\n\/* This banner’s background only *\/\n.nav-banner--megamaxx-brh {\n  background-image: url('https:\/\/cdn.shopify.com\/s\/files\/1\/1357\/3819\/files\/BlueRollHolderBG.jpg?v=1772124758');\n}\n\n\/* Mobile tweak *\/\n@media (max-width: 767px) {\n  .nav-banner {\n    height: 190px;\n    margin-top: 0;\n  }\n}\n\n\u003c\/style\u003e"},"menus":[]},{"id":"tmenu-menu-450730","setting":{"item_layout":"html","title":"Copy of Copy of Menu item","item_display":true,"column_width":"4","custom_html":"\u003ca href=\"https:\/\/www.indooroutdoors.co.uk\/collections\/welding-equipment\" title=\"Welding Equipment\"\u003e\n  \u003cdiv class=\"nav-banner nav-banner--welding\"\u003e\n    \u003cimg class=\"nav-banner__logo\"\n         alt=\"Welding Equipment\"\n         src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/1357\/3819\/files\/WeldingEquipment.png?v=1688047677\"\u003e\n  \u003c\/div\u003e\n\u003c\/a\u003e\n\n\u003cstyle\u003e\n\n\/* =========================\n   Base Reusable Banner Box\n   ========================= *\/\n\n.nav-banner {\n  width: 100%;\n  height: 220px;                 \/* Fixed tile height *\/\n  margin: 20px 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background-size: cover;\n  background-position: center;\n  position: relative;\n  overflow: hidden;\n}\n\n\/* Optional subtle dark overlay *\/\n.nav-banner::before {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  background: rgba(0,0,0,0.25);\n  pointer-events: none;\n}\n\n\/* =========================\n   Logo Rules (auto size safe)\n   ========================= *\/\n\n.nav-banner__logo {\n  position: relative;\n  z-index: 1;\n  max-width: min(360px, 85%);\n  max-height: 70%;\n  width: auto;\n  height: auto;\n  display: block;\n  transition: transform 0.25s ease;\n  will-change: transform;\n}\n\n\/* =========================\n   Shared Pulse Animation\n   ========================= *\/\n\n@keyframe